# cal.id → Airtable webhook (see app/api/cal-webhook/route.ts)

# Personal Access Token from https://airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write — access limited to the one base below.
AIRTABLE_API_KEY=

# Found in the base's API docs page: https://airtable.com/<BASE_ID>/api/docs
AIRTABLE_BASE_ID=

# Exact table name as created in Airtable (default assumed: "Bookings")
AIRTABLE_TABLE_NAME=Bookings

# Same secret string entered in cal.id → Settings → Developer → Webhooks
CAL_WEBHOOK_SECRET=
